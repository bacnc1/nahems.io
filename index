<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Khai báo sự cố thiết bị - NA-HEMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://unpkg.com/html5-qrcode"></script>
    <style>
        body { background-color: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .card { border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); border: none; }
        .header-title { color: #0056b3; font-weight: bold; }
        .btn-tag { border: 1px solid #dee2e6; background: #fff; margin-right: 5px; margin-bottom: 5px; font-size: 14px; }
        .btn-tag:hover { background: #e9ecef; }
        #reader { width: 100%; border-radius: 10px; overflow: hidden; display: none; }
    </style>
</head>
<body>

<div class="container mt-4">
    <div class="card p-4">
        <h2 class="header-title mb-1">KHAI BÁO SỰ CỐ</h2>
        <p class="text-muted small">Vui lòng điền đầy đủ thông tin bên dưới để bộ phận kỹ thuật hỗ trợ.</p>
        <hr>

        <form id="incidentForm">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label small fw-bold">📅 Ngày báo cáo:</label>
                    <input type="text" class="form-control bg-light" id="reportDate" readonly>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold">👤 Người báo cáo:</label>
                    <input type="text" class="form-control bg-light" value="dungnd" readonly>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold">⚠ Phân loại (*):</label>
                    <select class="form-select" required>
                        <option value="">-- Chọn loại sự cố --</option>
                        <option>Hỏng phần cứng</option>
                        <option>Lỗi phần mềm</option>
                        <option>Bảo trì định kỳ</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold">📍 Vị trí chi tiết:</label>
                    <input type="text" class="form-control" placeholder="Nhập vị trí...">
                </div>

                <div class="col-md-12">
                    <label class="form-label small fw-bold">📠 Thiết bị (*):</label>
                    <div class="input-group">
                        <input type="text" id="deviceName" class="form-control" placeholder="Chọn hoặc tìm kiếm thiết bị --" required>
                        <button class="btn btn-outline-primary" type="button" onclick="startQRScanner()">🔍 Quét mã QR</button>
                    </div>
                    <div id="reader" class="mt-2"></div>
                </div>

                <div class="col-md-12">
                    <label class="form-label small fw-bold">📝 Nội dung mô tả (*):</label>
                    <textarea class="form-control" rows="4" placeholder="Mô tả chi tiết sự cố..."></textarea>
                    <div class="mt-2">
                        <button type="button" class="btn btn-tag" onclick="addNote('Không hoạt động')">Không hoạt động</button>
                        <button type="button" class="btn btn-tag" onclick="addNote('Màn hình đen')">Màn hình đen</button>
                        <button type="button" class="btn btn-tag" onclick="addNote('Kêu to bất thường')">Kêu to bất thường</button>
                        <button type="button" class="btn btn-tag" onclick="addNote('Chảy nước')">Chảy nước</button>
                        <button type="button" class="btn btn-tag" onclick="addNote('Mất nguồn')">Mất nguồn</button>
                    </div>
                </div>

                <div class="col-md-12">
                    <label class="form-label small fw-bold">🖼 Ảnh đính kèm:</label>
                    <input type="file" class="form-control">
                </div>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <button type="button" class="btn btn-light me-2">Hủy bỏ</button>
                <button type="submit" class="btn btn-primary px-4">Gửi báo cáo</button>
            </div>
        </form>
    </div>
</div>

<script>
    // Tự động cập nhật thời gian thực
    function updateTime() {
        const now = new Date();
        document.getElementById('reportDate').value = now.toLocaleString('vi-VN');
    }
    setInterval(updateTime, 1000);
    updateTime();

    // Thêm ghi chú nhanh vào Textarea
    function addNote(text) {
        const textarea = document.querySelector('textarea');
        textarea.value += (textarea.value ? ', ' : '') + text;
    }

    // Xử lý Quét mã QR
    function startQRScanner() {
        const readerElement = document.getElementById('reader');
        readerElement.style.display = 'block';

        const html5QrCode = new Html5Qrcode("reader");
        const config = { fps: 10, qrbox: { width: 250, height: 250 } };

        html5QrCode.start({ facingMode: "environment" }, config, (decodedText) => {
            // Khi quét thành công
            document.getElementById('deviceName').value = "Thiết bị: " + decodedText;
            alert("Đã nhận diện mã thiết bị: " + decodedText);
            html5QrCode.stop();
            readerElement.style.display = 'none';
        }).catch((err) => {
            console.error("Lỗi Camera: ", err);
        });
    }
</script>

</body>
</html>
